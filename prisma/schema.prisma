generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
  LAWYER
}

model User {
  id         Int        @id @default(autoincrement())
  name       String
  email      String     @unique
  password   String
  role       UserRole   @default(STAFF)
  createdAt  DateTime   @default(now())
  lawyer     Lawyer?    @relation("LawyerToUser")
  appointmentsCreated Appointment[] @relation("CreatedBy")
  caseLogs   CaseLog[]
}

model Lawyer {
  id             Int           @id @default(autoincrement())
  user           User          @relation("LawyerToUser", fields: [userId], references: [id])
  userId         Int           @unique
  phone          String?
  specialization String?
  active         Boolean       @default(true)
  appointments   Appointment[]
}

model Appointment {
  id               Int        @id @default(autoincrement())
  clientName       String
  contactInfo      String
  date             DateTime
  startTime        String
  endTime          String
  caseType         String
  assignedLawyer   Lawyer?    @relation(fields: [assignedLawyerId], references: [id])
  assignedLawyerId Int?
  notes            String?
  status           String     @default("Scheduled")
  createdBy        User?      @relation("CreatedBy", fields: [createdById], references: [id])
  createdById      Int?
  createdAt        DateTime   @default(now())
  caseLogs         CaseLog[]

  @@index([date])
  @@index([assignedLawyerId])
}

model CaseLog {
  id            Int         @id @default(autoincrement())
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  appointmentId Int
  user          User?       @relation(fields: [userId], references: [id])
  userId        Int?
  action        String
  details       String?
  logTime       DateTime    @default(now())
}
